{
  "name": "pjkel.ly",
  "image": "hugomods/hugo:git-non-root-0.156.0",
  // Forward Hugo's dev server port
  "forwardPorts": [
    1313
  ],
  "portsAttributes": {
    "1313": {
      "label": "Hugo dev server",
      "onAutoForward": "openBrowser"
    }
  },
  // Start the dev server when the container opens
  "postStartCommand": "hugo server --bind 0.0.0.0 --port 1313 --disableFastRender",
  "customizations": {
    "vscode": {
      "extensions": [
        "budparr.language-hugo-vscode",
        "davidanson.vscode-markdownlint"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.insertFinalNewline": true,
        "files.trimTrailingWhitespace": false
      }
    }
  }
}
